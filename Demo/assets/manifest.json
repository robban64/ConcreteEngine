{
  "shaders": [
    {
      "name": "SpriteShader",
      "vertShaderPath": "sprite.vert.glsl",
      "fragShaderPath": "sprite.frag.glsl",
      "samplers": ["uTexture"]
    },
    {
      "name": "ScreenShader",
      "vertShaderPath": "screen.vert.glsl",
      "fragShaderPath": "screen.frag.glsl",
      "samplers": ["uTexture"]
    },
    {
      "name": "LightPassShader",
      "vertShaderPath": "screen.vert.glsl",
      "fragShaderPath": "light-pass.frag.glsl"
    },
    {
      "name": "LightComposite",
      "vertShaderPath": "screen.vert.glsl",
      "fragShaderPath": "light-composite.frag.glsl",
      "samplers": ["uSceneTex", "uLightTex"]
    }
  ],
  "textures": [
    {
      "name": "SpriteTexture",
      "path": "sprite.png"
    },
    {
      "name": "TilemapTextureAtlas",
      "path": "terrain_tiles.png",
      "preset": "NearestClamp",
      "lodBias": -0.25

    }
  ]
}