{
  "shaders": [
    {
      "name": "SpriteShader",
      "vertShaderPath": "sprite.vert.glsl",
      "fragShaderPath": "sprite.frag.glsl",
      "samplers": ["uTexture"]
    },
    {
      "name": "ScreenShader",
      "vertShaderPath": "screen.vert.glsl",
      "fragShaderPath": "screen.frag.glsl",
      "samplers": ["uTexture"]
    },
    {
      "name": "BlurHorizontal",
      "vertShaderPath": "screen.vert.glsl",
      "fragShaderPath": "blur_h.frag.glsl",
      "samplers": ["uTexture"]
    },
    {
      "name": "BlurVertical",
      "vertShaderPath": "screen.vert.glsl",
      "fragShaderPath": "blur_v.frag.glsl",
      "samplers": ["uTexture"]
    },
    {
      "name": "BrightPass",
      "vertShaderPath": "screen.vert.glsl",
      "fragShaderPath": "brightpass.frag.glsl",
      "samplers": ["uSceneTex"]
    },
    {
      "name": "ScreenComposite",
      "vertShaderPath": "screen.vert.glsl",
      "fragShaderPath": "composite.frag.glsl",
      "samplers": ["uSceneTex", "uBloomTex"]
    }
  ],
  "textures": [
    {
      "name": "SpriteTexture",
      "path": "sprite.png"
    },
    {
      "name": "TilemapTextureAtlas",
      "path": "terrain_tiles.png",
      "preset": "NearestClamp"

    }
  ]
}